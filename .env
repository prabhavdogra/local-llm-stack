# ── LLM Stack Configuration ──────────────────────────────────────────────────
# All services read from this file. No config lives anywhere else except models.yaml.

# Ports
LITELLM_PORT=4000
WEBUI_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# LiteLLM
LITELLM_MASTER_KEY=sk-llmstack-local

# Phase 1: MLX-LM on macOS (native, Apple Silicon)
MLX_PORT=8800
MLX_DEFAULT_MODEL=mlx-community/Qwen2.5-Coder-7B-Instruct-4bit

# Phase 2: uncomment when migrating to NVIDIA + vLLM
# VLLM_IMAGE=vllm/vllm-openai:latest
# VLLM_GPU_MEMORY_UTILIZATION=0.88
# VLLM_KV_CACHE_DTYPE=fp8
# VLLM_QUANTIZATION=awq_marlin
# VLLM_FLASH_ATTN_VERSION=2
# VLLM_MAX_BATCHED_TOKENS=4096

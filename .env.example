# ── Local LLM Stack — Example Config ────────────────────────────────────────
# Copy to .env and fill in real values. .env is gitignored.
#   make config          # copies this file to .env and generates secrets
#   make config FORCE=1  # overwrite .env and regenerate secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ─────────────────────────────────────────────────────────────────
# mlx    → Apple Silicon GPU via MLX-LM  (macOS, native process)
# nvidia → NVIDIA GPU via vLLM           (Linux, Docker + nvidia-container-toolkit)
BACKEND=nvidia

# ── Ports ───────────────────────────────────────────────────────────────────
# Services bind to 127.0.0.1 by default. To expose on LAN, edit docker-compose.yml.
LITELLM_PORT=4000
WEBUI_PORT=3001
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# ── Authentication (REQUIRED) ──────────────────────────────────────────────
# Generate strong values, e.g.:  openssl rand -hex 24
# Both vars are required — docker compose will refuse to start without them.
LITELLM_MASTER_KEY=sk-replace-me-with-a-strong-random-value
GRAFANA_ADMIN_PASSWORD=replace-me-with-a-strong-password

# ── Open WebUI Admin ──────────────────────────────────────────────────────
# Seeded automatically on first `make up`. Change after first login.
WEBUI_ADMIN_EMAIL=admin@localhost
WEBUI_ADMIN_PASSWORD=replace-me-with-a-strong-password

# ── LiteLLM Tuning ─────────────────────────────────────────────────────────
LITELLM_WORKERS=4

# ── MLX Backend (macOS / Apple Silicon) ─────────────────────────────────────
MLX_PORT=8800
MLX_MODEL=mlx-community/Qwen2.5-Coder-7B-Instruct-4bit

# ═════════════════════════════════════════════════════════════════════════════
# NVIDIA GPU — Set VLLM_MODEL and run `make restart`.
# ═════════════════════════════════════════════════════════════════════════════
VLLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=32768
VLLM_TENSOR_PARALLEL_SIZE=1

# Quick-switch alternates:
# VLLM_MODEL=Qwen/Qwen3-Coder-Next              # BF16, needs >160 GB
# VLLM_MODEL=bullpoint/Qwen3-Coder-Next-AWQ-4bit # AWQ INT4, ~40 GB
# VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# VLLM_MODEL=Qwen/Qwen3-8B

# ── Hugging Face [CONDITIONAL — see `make check-env`] ───────────────────────
# Required when VLLM_MODEL is gated/private on Hugging Face (e.g. meta-llama/*).
# Optional for most public models (Qwen, etc.). Uncomment and set:
# HF_TOKEN=hf_your_token_here

# ── ngrok [CONDITIONAL — required for `make up-ngrok`] ─────────────────────
# Both must be set together. Get credentials at https://dashboard.ngrok.com
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# NGROK_DOMAIN=your-name.ngrok-free.app

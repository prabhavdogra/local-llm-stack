      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (requested_model) (rate(litellm_input_tokens_metric_total{job=\"litellm\"}[5m]))",
          "legendFormat": "Input — {{requested_model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (requested_model) (rate(litellm_output_tokens_metric_total{job=\"litellm\"}[5m]))",
          "legendFormat": "Output — {{requested_model}}",
          "refId": "B"
        }

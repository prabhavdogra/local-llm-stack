# ── Local LLM Stack Configuration ───────────────────────────────────────────
# Single config file for the entire stack. Toggle BACKEND to switch engines.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ─────────────────────────────────────────────────────────────────
# mlx    → Apple Silicon GPU via MLX-LM  (macOS, native process)
# nvidia → NVIDIA GPU via vLLM           (Linux, Docker + nvidia-container-toolkit)
BACKEND=nvidia

# ── Ports ───────────────────────────────────────────────────────────────────
# LiteLLM and WebUI bind 0.0.0.0 — reachable from other machines on the LAN.
LITELLM_PORT=4000
WEBUI_PORT=3001
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# ── Authentication ──────────────────────────────────────────────────────────
# Every API consumer must send this as a Bearer token.
# >>> CHANGE THIS for production <<<
LITELLM_MASTER_KEY=sk-llmstack-local

# ── LiteLLM Tuning ─────────────────────────────────────────────────────────
LITELLM_WORKERS=4

# ── MLX Backend (macOS / Apple Silicon) ─────────────────────────────────────
MLX_PORT=8800
MLX_MODEL=mlx-community/Qwen2.5-Coder-7B-Instruct-4bit

# ═════════════════════════════════════════════════════════════════════════════
# NVIDIA GPU — Single model on the DGX Spark (122 GB usable VRAM).
#
# Change VLLM_MODEL and run `make restart` — nothing else to edit.
# ═════════════════════════════════════════════════════════════════════════════

VLLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=32768
VLLM_TENSOR_PARALLEL_SIZE=1

# Quick-switch: uncomment one, comment the active VLLM_MODEL above.
# VLLM_MODEL=Qwen/Qwen3-Coder-Next              # BF16, needs >160 GB
# VLLM_MODEL=bullpoint/Qwen3-Coder-Next-AWQ-4bit # AWQ INT4, ~40 GB
# VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# VLLM_MODEL=Qwen/Qwen3-8B

# ── API Keys (set in .env, never commit) ──────────────────────────────────
# HF_TOKEN=hf_your_token_here

# ── ngrok Tunnel (public HTTPS for Cursor IDE integration) ────────────────
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# NGROK_DOMAIN=your-name.ngrok-free.app